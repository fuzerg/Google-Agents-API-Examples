# Atlassian Chat Agent — credentials for the Rovo MCP server.
# Copy to `.env` and fill in. `.env` is git-ignored; never commit real tokens.
#
# Load into your shell before running chat.py, e.g.:
#   set -a && source .env && set +a
#   ./venv/bin/python3 chat.py --check

# --- Basic auth (personal API token) — the default (auth.mode: basic) ---
# IMPORTANT: for the Rovo MCP server you need a SCOPED token (created via the
# MCP flow), not a classic token. See README troubleshooting.
# Create one: https://id.atlassian.com/manage-profile/security/api-tokens?appId=mcp&selectedScopes=all
ATLASSIAN_EMAIL="your.email@example.com"
ATLASSIAN_API_TOKEN="your_scoped_api_token"

# --- Demo seeding only (demo/seed_demo.py) ---
# Your Atlassian site URL; the demo seeder derives the cloud id from it.
ATLASSIAN_SITE="https://your-site.atlassian.net"
# Optional: set the cloud id explicitly instead of deriving it from the site.
# ATLASSIAN_CLOUD_ID="00000000-0000-0000-0000-000000000000"

# --- Bearer auth (service-account API key) — only if you run --auth-mode bearer ---
# Ask your Atlassian admin to create a service account + API key.
# ATLASSIAN_API_KEY="your_service_account_api_key"

# --- Interactions API (Data Plane) ---
# Optional: overrides the ADC-resolved project.
# GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
