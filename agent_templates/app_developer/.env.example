# App Development Agent — credentials for the GitHub remote MCP server.
# Copy to `.env` and fill in (or just `export GITHUB_TOKEN=...` in your shell).
# `.env` is git-ignored; never commit real tokens. The runner (prober.py)
# auto-loads this file.

# --- GitHub credentials ---
# A Personal Access Token (PAT). Permissions depend on the mode you run:
#   Feature mode (existing repo -> PR): on the target repo,
#     Contents: Read and write  and  Pull Requests: Read and write.
#   Greenfield mode (create a new repo): permission to CREATE repositories,
#     e.g. a classic token with the `repo` scope.
# The simplest token that covers both modes is a classic token with `repo`.
# agent.yaml sends it to the remote MCP server as:
#   Authorization: "Bearer ${GITHUB_TOKEN}"
GITHUB_TOKEN="github_pat_your_token_value_here"

# --- GCS bucket for the bundled skill ---
# The whole local `skills/` folder is mirrored here and mounted into the sandbox.
# Required for this template. Use a bucket you own; agent.yaml references it as
# `gs://${GCS_BUCKET}/app_developer/skills`.
GCS_BUCKET="your-gcs-bucket-name"

# --- Interactions API (Data Plane) ---
# Optional: overrides the ADC-resolved project.
# GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
